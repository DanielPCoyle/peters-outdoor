generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Tour {
  id          String      @id @default(uuid())
  name        String
  tagline     String
  description String
  price       Decimal     @db.Decimal(10, 2)
  duration    String      @default("2–3 hours")
  imageUrl    String
  wildlife    String[]
  isActive             Boolean   @default(true)
  sortOrder            Int       @default(0)
  maxGuests            Int       @default(8) @map("max_guests")
  privatePartyEnabled  Boolean   @default(false) @map("private_party_enabled")
  privatePartyRate     Decimal?  @db.Decimal(10, 2) @map("private_party_rate")
  location             String?
  locationUrl          String?   @map("location_url")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  addOns      TourAddOn[]
  timeSlots   TourTimeSlot[]

  @@map("tours")
}

model AddOn {
  id          String      @id @default(uuid())
  name        String
  description String      @default("")
  price       Decimal     @db.Decimal(10, 2)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  tours       TourAddOn[]

  @@map("add_ons")
}

model TourAddOn {
  tourId  String
  addOnId String
  tour    Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  addOn   AddOn  @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([tourId, addOnId])
  @@map("tour_add_ons")
}

model TourTimeSlot {
  id          String   @id @default(uuid())
  tourId      String   @map("tour_id")
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  time        String   // "09:00" 24-hour format
  type        String   @default("specific") // "specific" | "recurring"
  dates       String[] @default([])         // YYYY-MM-DD for specific type
  startDate   String?  @map("start_date")   // for recurring
  repeatEvery String?  @map("repeat_every") // "daily" | "weekly" | "monthly"
  repeatCount Int?     @map("repeat_count") // how many occurrences
  timeFrame   String?  @map("time_frame")   // e.g. "Morning", "Sunset"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tour_time_slots")
}

model Waiver {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now()) @map("created_at")
  fullName      String   @map("full_name")
  email         String?
  tourDate      String?  @map("tour_date")
  signatureData String   @map("signature_data")
  ipAddress     String?  @map("ip_address")

  @@map("waivers")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

model PrivateTour {
  id                    String    @id @default(uuid())
  slug                  String    @unique
  title                 String
  description           String    @default("")
  date                  String
  time                  String?
  guests                Int       @default(1)
  price                 Decimal   @db.Decimal(10, 2)
  location              String?
  notes                 String?
  clientName            String    @map("client_name")
  clientEmail           String    @map("client_email")
  status                String    @default("pending")
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("private_tours")
}

model Settings {
  key   String @id
  value String

  @@map("settings")
}

model DiscountCode {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    @default("percentage") @map("discount_type")
  discountValue Float     @map("discount_value")
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  expiresAt     DateTime? @map("expires_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("discount_codes")
}

model GiftCertificate {
  id                    String    @id @default(uuid())
  createdAt             DateTime  @default(now()) @map("created_at")
  status                String    @default("pending_payment")
  yourName              String    @map("your_name")
  yourEmail             String    @map("your_email")
  recipientName         String?   @map("recipient_name")
  message               String?
  amount                Decimal   @db.Decimal(10, 2)
  certificateCode       String?   @map("certificate_code")
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  sentAt                DateTime? @map("sent_at")
  redeemedAt            DateTime? @map("redeemed_at")

  @@map("gift_certificates")
}
